<%= content_for :body_class, "loading authentication-bg" %>

<div class="account-pages pt-2 pt-sm-5 pb-4 pb-sm-5">
  <div class="container">
      <div class="row justify-content-center">
          <div class="col-xxl-4 col-lg-5">
              <div class="card">
                  <!-- Logo -->
                  <div class="card-header pt-4 pb-4 text-center bg-primary">
                      <a href="<%= root_url %>">
                          <span>
                            <%= image_pack_tag 'media/images/logo.png', alt: '', height: '18'%>
                          </span>
                      </a>
                  </div>
                  
                  <div class="card-body p-4">
                      
                      <div class="text-center  m-auto">
                          <h4 class=" text-center mt-0 fw-bold">Restablecer contraseña</h4>
                          <p class="text-muted mb-4">Ingresá tu e-mail y recibirás un correo con las instrucciones para restablecer tu contraseña.</p>
                      </div>

                      <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
                          <%= render "devise/shared/error_messages", resource: resource %>

                          <div class="mb-3">
                            <%= f.label :email, class: "form-label" %>
                            <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-control", required: "", placeholder: "Ingresar e-mail" %>
                          </div>

                          <div class="mb-0 text-center">
                            <%= f.submit "Restablecer contraseña", class: "btn btn-primary" %>
                          </div>
                      <% end %>
                  </div> <!-- end card-body-->
              </div>
              <!-- end card -->

              <div class="row mt-3">
                  <div class="col-12 text-center">
                      <p class="text-muted">Volver a <a href="<%= new_user_session_path %>" class="text-muted ms-1"><b>Iniciar sesión</b></a></p>
                  </div> <!-- end col -->
              </div>
              <!-- end row -->

          </div> <!-- end col -->
      </div>
      <!-- end row -->
  </div>
  <!-- end container -->
</div>
<!-- end page -->