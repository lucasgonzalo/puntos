<!-- lib/templates/erb/scaffold/show.html.erb.tt -->

<% set_page_title("Sucursal de #{@branch.company.name}") %>

<div class="row">
  <div class="col-12">
    <div class="card">
      <div class="card-body">
        <div class="m-2 col-12">
          <div class="container mx-auto my-2 px-4">
            <div class="col-lg-4">
              <%= render partial: 'branch', locals: { branch: @branch } %>
            </div>

            <div class="d-flex bd-highlight mt-4">
              <div class="p-2 bd-highlight">
                <%= link_to 'Volver', @branch.company, class: "btn btn-secondary" %>
              </div>

              <div class="ms-auto p-2 bd-highlight">
                <% if can? :destroy, @branch %>
                  <%= render 'shared/destroy', element: @branch %>
                <% end %>
              </div>
            </div>
        </div>
      </div>
    </div>
  </div>
</div>