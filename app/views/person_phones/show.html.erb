<% set_page_title("Dirección de #{@person_phone.person.full_name}") %>

<div class="row">
  <div class="col-12">
    <div class="card">
      <div class="card-body">
        <div class="m-2 col-12">
          <div class="container mx-auto my-2 px-4">
            <div class="col-lg-4">
              <%= render partial: 'phone', locals: {person_phone: @person_phone } %>
            </div>

            <div class="d-flex bd-highlight mt-4">
              <div class="p-2 bd-highlight">
                <%= link_to 'Volver',  request.referer , class: "btn btn-secondary" %>
              </div>

              <div class="ms-auto p-2 bd-highlight">
                <% if can? :destroy, @person_phone %>
                  <%= render 'shared/destroy', element: @person_phone %>
                <% end %>
              </div>
            </div>
        </div>
      </div>
    </div>
  </div>
</div>