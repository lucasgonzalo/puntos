  </div>


<%= button_to "Limpiar carpeta de archivos temporales", clear_tmp_pdfs_redis_keys_path, method: :post, class: "btn btn-danger", data: { confirm: "¿Seguro desea eliminar todos los archivos temporales de la carpeta tmp/pdfs ?" } %>


<script>
  function copyToClipboard(text) {
    const tempInput = document.createElement("input");
    tempInput.style.position = "absolute";
    tempInput.style.left = "-9999px";
    tempInput.value = text;
    document.body.appendChild(tempInput);
    tempInput.select();
    document.execCommand("copy");
    document.body.removeChild(tempInput);
    toastr.success("Copied to clipboard!");
  }

  function copyAllKeys() {
    try {
      const rows = document.querySelectorAll('#scroll-horizontal-datatable tbody tr');
      const text = Array.from(rows).map(row => {
        const key = row.cells[0].textContent.trim();
        const value = row.cells[1].textContent.trim();
        return `${key}\t${value}`;  // Tabulación como separador
      }).join('\n');
      
      navigator.clipboard.writeText(text).then(() => {
        toastr.success("Claves copiadas para pegar en Excel (Columna A: claves, Columna B: valores)");
      }).catch(err => {
        // Fallback para navegadores antiguos
        const tempInput = document.createElement("textarea");
        tempInput.value = text;
        document.body.appendChild(tempInput);
        tempInput.select();
        document.execCommand("copy");
        document.body.removeChild(tempInput);
        toastr.success("Claves copiadas para pegar en Excel (Columna A: claves, Columna B: valores)");
      });
    } catch (error) {
      toastr.error("Error al copiar las claves: " + error.message);
    }
  }
</script>