<div class="modal fade" id="new_redis_key" aria-hidden="true" aria-labelledby="exampleModalToggleLabel" tabindex="-1">
  <div class="modal-dialog ">
    <div class="modal-content">
      <div class="modal-header modal-colored-header bg-primary">
        <h5 class="modal-title" id="exampleModalToggleLabel">Nueva Redis</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <%= form_with(url: redis_keys_path, method: :post, local: true) do |form| %>
        <div class="modal-body p-2">
          <div class="mb-3">
            <%= form.label :redis_key, "Clave:" %> 
            <%= form.text_field :redis_key, class: "form-control", placeholder:"Ingrese Clave",  required: true  %>
          </div> 
          <div class="mb-3">
            <%= form.label :redis_value, "Valor:" %> 
            <%= form.text_field :redis_value, class: "form-control", placeholder:"Ingrese Valor",  required: true  %>
          </div> 
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-danger" data-bs-dismiss="modal">Cancelar</button>
          <%= form.submit "Confirmar", class: "btn btn-primary " %>    
        </div>
      <% end %>
    </div><!-- /.modal-content -->
  </div><!-- /.modal-dialog -->
</div><!-- /.modal -->   