<!-- lib/templates/erb/scaffold/show.html.erb.tt -->

<% set_page_title("Persona") %>

<div class="card">
  <div class="card-body">
    <div class="container">
      <div class="col-lg-12">
        <div class="card border">
          <div class="card-body">

            <h2 class="header-title mb-2"><%= @person.full_name %></h2>
            <hr>

            <div class="row mb-2">
              <div class="col-6 row">
                <div class="col-4"><span class="fw-bold me-2">Apellido:</span></div>
                <div class="col-8"><%= @person.last_name %></div>
              </div>
              <div class="col-6 row">
                <div class="col-4"><span class="fw-bold me-2">Nombre:</span></div>
                <div class="col-8"><%= @person.first_name %></div>
              </div>
            </div>

            <div class="row mb-2">
              <div class="col-6 row">
                <div class="col-4"><span class="fw-bold me-2">Tipo de Documento:</span></div>
                <div class="col-8"><%= Person.document_types[@person.document_type] %></div>
              </div>
              <div class="col-6 row">
                <div class="col-4"><span class="fw-bold me-2">Número de Documento:</span></div>
                <div class="col-8"><%= @person.document_number %></div>
              </div>
            </div>

            <div class="row mb-2">
              <div class="col-6 row">
                <div class="col-4"><span class="fw-bold me-2">Fecha de Nacimiento:</span></div>
                <div class="col-8"><%= @person.formatted_date_birth %></div>
              </div>
              <div class="col-6 row">
                <div class="col-4"><span class="fw-bold me-2">Género:</span></div>
                <div class="col-8"><%= Person.genders[@person.gender] %></div>
              </div>
            </div>

            <div class="row mb-2">
              <div class="row">
                <div class="col-12"><%= get_badges_person(@person) %></div>
              </div>
            </div>

          </div>
        </div>
      </div>

      <ul class="nav nav-tabs mt-4 mb-3">
        <li class="nav-item">
          <a href="#addresses" data-bs-toggle="tab" aria-expanded="false" class="nav-link active">
            <i class="mdi mdi-home-variant d-md-none d-block"></i>
            <span class="d-none d-md-block">
              Direcciones
            </span>
          </a>
        </li>
        <li class="nav-item">
          <a href="#emails" data-bs-toggle="tab" aria-expanded="true" class="nav-link">
            <i class="mdi mdi-account-circle d-md-none d-block"></i>
            <span class="d-none d-md-block">
              E-mails
            </span>
          </a>
        </li>
        <li class="nav-item">
          <a href="#phones" data-bs-toggle="tab" aria-expanded="false" class="nav-link">
            <i class="mdi mdi-settings-outline d-md-none d-block"></i>
            Teléfonos
          </a>
        </li>
      </ul> 
      
      <div class="tab-content ">
        <!-------------------------------------------DIRECCIÓN-------------------------------------------------------------->
        <div class="tab-pane show active" id="addresses">
          <%= link_to 'Agregar', 
              new_person_address_url(person: @person, customer: nil), 
              class: 'btn btn-primary' if can? :create, PersonAddress.new
          %>
          <p><%= render partial: "people/list_addresses", locals: {
              person: @person, 
              person_addresses: @person.person_addresses, 
              customer: nil
            }%></p>
        </div>
        <!-------------------------------------------EMAILS-------------------------------------------------------------->
        <div class="tab-pane" id="emails">
          <%= link_to 'Agregar', 
              new_person_email_url(person: @person, customer: nil), 
              class: 'btn btn-primary' if can? :create, PersonEmail.new
          %>
          <p><%= render partial:"people/list_emails", locals: {
              person: @person, 
              person_emails: @person.person_emails,
              customer: nil
            }%></p>
        </div>
        <!-------------------------------------------TELÉFONO-------------------------------------------------------------->
        <div class="tab-pane" id="phones">
          <%= link_to 'Agregar', 
              new_person_phone_url(person: @person, customer: nil), 
              class: 'btn btn-primary' if can? :create, PersonPhone.new
          %>
          <p><%= render partial: "people/list_phones", locals: {
            person: @person, 
            person_phones: @person.person_phones,
            customer: nil
          }%></p>
        </div>
      </div>

      <div class="d-flex bd-highlight mb-3">
        <div class="p-2 bd-highlight">
          <%= link_to 'Volver', people_path, class: "btn btn-secondary" %>
        </div>
        <div class="ms-auto p-2 bd-highlight">
          <% if can? :destroy, @person %>
            <%= render 'shared/destroy', element: @person %>
          <% end %>
        </div>
      </div>

    </div>
  </div>
</div>