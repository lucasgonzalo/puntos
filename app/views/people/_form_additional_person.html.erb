
<%#= render "shared/error_messages", resource: form.object %>

<h4 class=" text-center mt-0 fw-bold">Datos Personales</h4>
<div class="row g-2">
    <div class="form-floating mb-3 col-md-6">
        <%= form.text_field :first_name, class: "form-control", placeholder:"Ingrese first_name", required: true%>
        <%= form.label :first_name, "Nombre/s", for: "floatingInput" %>
        <div class="valid-feedback">Correcto!</div>
        <div class="invalid-feedback">Ingrese una Dirección</div>
    </div>
    <div class="form-floating mb-3 col-md-6">
        <%= form.text_field :last_name, class: "form-control", placeholder:"Ingrese last_name", required: true%>
        <%= form.label :last_name, "Apellido/s", for: "floatingInput" %>
        <div class="valid-feedback">Correcto!</div>
        <div class="invalid-feedback">Ingrese una Dirección</div>
    </div>
</div>

<div class="row g-2">
    <div class="form-floating mb-3 col-md-6">
        <%= form.collection_select :document_type, Person.document_types.map {|value| [value.first, value.second]}, :first, :second, {prompt: "Seleccione Tipo de Documento"}, {class: "form-select", required: true} %>
        <%#= form.label :document_type,"Apellido/s", for: "floatingInput" %>
        <div class="valid-feedback">Correcto!</div>
        <div class="invalid-feedback">Ingrese una Dirección</div>
    </div>
    <div class="form-floating mb-3 col-md-6">
        <%= form.text_field :document_number, class: "form-control", placeholder:"Ingrese document_number", required: true%>
        <%= form.label :document_number,"Número de Documento", for: "floatingInput" %>
        <div class="valid-feedback">Correcto!</div>
        <div class="invalid-feedback">Ingrese una Dirección</div>
    </div>
</div>

<div class="row g-2">
    <div class="form-floating mb-3 col-md-6">
        <%= form.date_field :birth_date, class: "form-control", placeholder:"Ingrese birth_date" %>
        <%= form.label :birth_date, "Fecha de Nacimiento", for: "floatingInput" %>
    </div>
    <div class="form-floating mb-3 col-md-6">
        <%= form.collection_select :gender, Person.genders.map {|value| [value.first, value.second]}, :first, :second, {prompt: "Seleccione Género"}, {class: "form-select"} %>
        <%#= form.label :gender, "Género" ,for: "floatingInput" %>
    </div>
</div>

<br/>

<!--------------------------------Dirección------------------------------------->
<h4 class=" text-center mt-0 fw-bold">Dirección</h4>
<div class="row g-2">
  <div class="form-floating mb-3 col-md-9">
    <%= form.text_field :address, class: "form-control input-lg", placeholder: "Dirección" , required: true %>
    <%= form.label :address, "Dirección", for: "floatingInput"%>
    <div class="valid-feedback">Correcto!</div>
    <div class="invalid-feedback">Ingrese una Dirección</div>
  </div>
  <div class="form-floating mb-3 col-md-3">
    <%= form.text_field :postal_code, class: "form-control input-lg", placeholder: "Código Postal" %>
    <%= form.label :postal_code, "Código Postal",for: "floatingInput"%>
    <div class="valid-feedback">Correcto!</div>
    <div class="invalid-feedback">Ingrese un Código Postal</div>
  </div>
</div>

<div class="row g-2">
  <div class="form-floating mb-3 col-md-12">
    <%= render partial: 'cities/collections_fields', locals: { form: form } %>
  </div>
</div>

<br/>

<!--------------------------------Email----------------------------------------->
<h4 class=" text-center mt-0 fw-bold">Email</h4>

<div class="row g-2">
  <div class="form-floating mb-3 col-md-12">
    <%= form.text_field :email, class: "form-control input-lg", placeholder: "Email"  %>
    <%= form.label :email, for: "floatingInput"%>
    <div class="valid-feedback">Correcto!</div>
    <div class="invalid-feedback">Ingrese un Email</div>
  </div>
</div>

<br/>

<!--------------------------------Telefono------------------------------------->
<h4 class=" text-center mt-0 fw-bold">Teléfono</h4>
<div class="row g-2">
  <div class="form-floating mb-3 col-md-6">
      <%= form.collection_select :phone_type, PersonPhone.phone_types.map {|value| [value.first, value.second]}, :first, :second, {prompt: "Seleccione Tipo de Teléfono"}, {class: "form-select"} %>
      <%#= form.label :phone_type ,  for: "floatingInput"%>
      <div class="valid-feedback">Correcto!</div>
      <div class="invalid-feedback">Ingrese un Tipo de Teléfono</div>
  </div>
  <div class="form-floating mb-3 col-md-6">
      <%= form.collection_select :country_code, PersonPhone.country_codes.values.map {|value| [value[0], "("+value[1]+")"+" "+ value[0]]}, :first, :second, {prompt: "Seleccione Codigo de País"}, {class: "form-select"} %>
      <%#= form.label :country_code, for: "floatingInput" %>
      <div class="valid-feedback">Correcto!</div>
      <div class="invalid-feedback">Ingrese una Código de País</div>
  </div>
</div>

<div class="row g-2">
  <div class="form-floating mb-3 col-md-3"> 
      <%= form.text_field :area_code, class: "form-control input-lg", placeholder: "Código de área" %>
      <%= form.label :area_code, "Código de área" ,for: "floatingInput"%>
      <div class="valid-feedback">Correcto!</div>
      <div class="invalid-feedback">Ingrese un Código Área</div>
  </div>
  <div class="form-floating mb-3 col-md-9"> 
      <%= form.text_field :phone_number, class: "form-control input-lg", placeholder: "Número de Teléfono" %>
      <%= form.label :phone_number, "Número de Teléfono" , for: "floatingInput"%>
      <div class="valid-feedback">Correcto!</div>
      <div class="invalid-feedback">Ingrese un Número de Teléfono</div>
  </div>
</div>

