<table id="datatable-buttons" class="table table-striped dt-responsive nowrap ">
  <thead>
    <tr>
      <th class="p-3 uppercase text-left text-xs text-gray-700">Código de Area</th>                                
      <th class="p-3 uppercase text-left text-xs text-gray-700">Telefonos</th> 
      <th class="p-3 uppercase text-left text-xs text-gray-700">Tipo</th>  
      <th class="p-3 uppercase text-left text-xs text-gray-700"></th>                                             
      <th class="p-3 uppercase text-left text-xs text-gray-700">Acciones</th>
    </tr>
  </thead>

  <tbody>
    <% if person_phones.exists? %>
      <% person_phones.each do |person_phone| %>
        <tr class="group border-t border-gray-400 hover:bg-gray-100">
          <td class="p-3"><%= person_phone.area_code %></td>
          <td class="p-3"><%= person_phone.phone_number %></td>
          <td class="p-3"><%= PersonPhone.phone_types[person_phone.phone_type]%></td>
          <td class="p-3"><%= get_badges_person_phone(person_phone) %></td>
          <td>
            <%= link_to 'Ver', person_phone_path(id: person_phone, customer: !customer.blank? ? customer.id : ''), class: "btn btn-outline-danger my-1" if can? :read, person_phone %>
            <%= link_to 'Editar', edit_person_phone_path(id: person_phone, customer: !customer.blank? ? customer.id : ''), class: "btn btn-outline-danger" if can? :edit, person_phone %>
          </td>
        </tr>
      <% end %>
    <%else%>
      <td class="p-3" colspan="5">No se encontraron teléfonos registrados</td>
    <%end%>
  </tbody>
</table>