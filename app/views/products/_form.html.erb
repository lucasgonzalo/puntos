<div data-controller="products">
  <%= form_with(model: [@catalog, @product], local: true, html: { multipart: true }) do |form| %>

    <%= render "shared/error_messages", resource: form.object %>
    <div class="mb-3">
      <%= form.label :name, "Nombre" %>
      <%= form.text_field :name, class: "form-control", required: true %>
    </div>

    <div class="mb-3">
      <%= form.label :description, "Descripción" %>
      <%= form.text_area :description, class: "form-control" %>
    </div>

    <div class="form-floating mb-3">
      <%#= form.label :product_type, "Tipo de producto" %>
      <%= form.select :product_type, Product.product_types.map{ |type| [ type[1], type[0] ] },
        { prompt: "Seleccione Tipo"},
        { id: "group_id", class: "form-select", required: true, onchange: "",
         data: {products_target: "productType", action: "change->products#selectedType"}
        }
        
      %>
    </div>

    <div class="mb-3">
      <%= form.label :points, "Puntos" %>
      <%= form.number_field :points, step: 1, class: "form-control", required: true %>
    </div>

    <div class="mb-3">
      <%= form.label :price, "Precio" %>
      <%= form.number_field :price, step: 0.01, class: "form-control", data: { products_target: "priceField" } %>
    </div>

    <div class="mb-3" >
      <%= form.label :image, "Imagen del producto - Tamaño recomendado 500x400 px.", class: "form-label" %>
      
<%= form.file_field :image, class: "form-control", id: "product-image", data: { products_target: "imageInput", action: "change->products#validateImage" }, accept: ".jpg,.jpeg,.png,.webp" %>

      <div id="image-error" class="text-danger mt-2" data-products-target="imageError"></div>
      <div id="image-preview" class="mt-3" data-products-target="imagePreview"></div>
    </div>

    <%= form.submit class: "btn btn-primary" %>
  <% end %>
</div>




