<div class="container mt-4">
  <table id="alerts-table2" class="table table-striped table-bordered dt-responsive nowrap" style="width:100%">

    <thead>
      <tr>
        <th>ID</th>
        <th>Categoría</th>
        <th>Estado</th>
        <th>Contenido</th>
        <th>Acciones</th>
      </tr>
    </thead>
    <tbody>
      <% @alerts.each do |alert| %>
        <tr>
          <td><%= alert.id %></td>
          <td><%= alert.category %></td>
          <td><%= alert.status %></td>
          <td><%= alert.content %></td>
          <td>
            <%= link_to "Ver", alert_path(alert), class: "btn btn-outline-danger btn-sm" %>
            <%= link_to "Editar", edit_alert_path(alert), class: "btn btn-outline-danger btn-sm" %>
            <%= link_to "Eliminar", alert_path(alert), method: :delete, data: { confirm: "¿Estás seguro?" }, class: "btn btn-outline-danger btn-sm" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>



<%#= render partial: 'layouts/index_js' %>

<script type="module">
  import "datatables.net";
  import "datatables.net-bs5";

  document.addEventListener("turbo:load", () => {
    const tableElement = document.querySelector('#alerts-table');
    if (tableElement && !$.fn.DataTable.isDataTable(tableElement)) {
      $(tableElement).DataTable({
        paging: true,
        searching: true,
        ordering: true,
        info: true,
        responsive: true,
        language: {
          url: "//cdn.datatables.net/plug-ins/1.13.5/i18n/es-MX.json"
        }
      });
    }
  });

</script>