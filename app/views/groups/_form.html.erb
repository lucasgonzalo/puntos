<%= form_with(model: group) do |form| %>
  <%= render "shared/error_messages", resource: form.object %>

  <div class="form-floating mb-3">
    <%= form.text_field :name, class: "form-control", placeholder:"Ingrese nombre" %>
    <%= form.label :name, "Nombre", for: "group_name" %>
  </div>

  <div class="form-floating mb-3">
    <%= form.select :account_type, Group.account_types.keys.map { |type| [I18n.t("activerecord.attributes.group.account_types.#{type}"), type] }, { selected: form.object.account_type }, class: ["form-select"] %>
    <%= form.label :account_type, for: "floatingInput" %>
  </div>

  <div class="form-floating mb-3">
    <%= form.text_area :description, class: "form-control", placeholder:"Ingrese descripción" %>
    <%= form.label :description, "Descripción", for: "floatingInput" %>
  </div>

  <div class="form-floating mb-3">
    <%= form.file_field :image, multiple: false, class: "form-control" %>
    <%= form.label :image, "Imagen", for: "floatingInput" %>

    <% if form.object && form.object.image.attached? %>
      <div class="col-md-6 col-sm-12 mb-4">
        <div class="form-group">
          <%= image_tag url_for(form.object.image), style:"max-height:200px; max-width: 200px" %>
        </div>
        <div class="form-group">
          <label>
            <%= form.check_box :remove_image %>
            Eliminar imagen
          </label>
        </div>
      </div>
    <% end %>
  </div>


  <div class="justify-between items-center">
    <%= form.button "Guardar", class: "btn btn-primary" %>
  </div>  
<% end %>