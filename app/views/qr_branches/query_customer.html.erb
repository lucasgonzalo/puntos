<%= content_for :body_class, "loading authentication-bg" %>


<style>
  .my-fancy-background {
    position: relative;
    background-color: transparent;
  }

  .my-fancy-background::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-position: center;
    background-color: #7aa4f0;
    background-repeat: no-repeat;
    background-size: cover;
    opacity: 4; 
    filter: brightness(0.75); 
    z-index: -1;
  }
</style>

<div class="account-pages pt-2 pt-sm-5 pb-4 pb-sm-7 ">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-xxl-6 col-lg-12">
        <div class="card py-4">
          <div class="card-body p-12">

            <!------------------------- Encabezado ----------------------------->
            <div class="text-center  m-auto">
              <% if @branch.image_branch.attached? %>
                <%= image_tag @branch.image_branch, alt: "", height: "60" %>
              <% end %>
            </div>
            <br>
            <div class="text-center  m-auto">
                <%if @company.groups&.first.account_type_group? %>
                  <h1 class="  text-center mt-0 fw-bold"><%= @company.groups.first.name %></h1>
                <% else %>
                 <h1 class="  text-center mt-0 fw-bold"><%= @branch.name+' - '+@company.name %></h1>
                <% end %>
            </div>
            <br>

            <!------------------------- Buscador de Persona por DNI ----------------------------->
            <div class="row my-4">
              <div class="col-9 offset-2">
                <div class="row mb-2">
                  <h3 class=" ">Buscar persona</h3>
                  <%#= "company: #{@company.id}, branch: #{@branch.id} " %>
                  <%#= @company.active_group.account_type_group? ? "acumula por entidad" : "acumula por comercio"%>
                  <%= turbo_frame_tag "person_search_form", data: { turbo: true } do %>
                    <%= render partial: 'search_person/form_search', locals: {company: @company, branch: @branch}  %>
                  <% end %>
                </div>
              </div> 
            </div>

            <hr/>
            <!------------------------- Resultado de Existencia de Persona ----------------------------->
            <div class="row">
              <%= turbo_frame_tag "person_search_result", data: { turbo: true } %>
            </div>
            <br/>
            <!------------------------- Resultado de Beneficiario de Comercio----------------------------->
            <div class="row">
              <%= turbo_frame_tag "customer_search_result", data: { turbo: true } %>
            </div>
   
          </div>
        </div>
      </div>
    </div>
  </div>
</div>