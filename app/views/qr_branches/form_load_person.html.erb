

<%= content_for :body_class, "loading authentication-bg" %>

<style>
  .my-fancy-background {
    position: relative;
    background-color: transparent;
  }

  .my-fancy-background::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
     background-color: #7aa4f0;
    background-position: center;
    background-repeat: no-repeat;
    background-size: cover;
    opacity: 4; 
    filter: brightness(0.75); 
    z-index: -1;
  }
</style>

<div class="account-pages pt-2 pt-sm-5 pb-4 pb-sm-5">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-xxl-8 col-lg-7">
          <div class="card <%= 'my-fancy-background' if Company.find_by(token: @token_company).name=='Bixi' %> ">
            <div class="card-body p-4">
              <div class="text-center  m-auto">
                <% if Company.find_by(token: @token_company).image_company.attached? %>
                  <%= image_tag Company.find_by(token: @token_company).image_company, alt: "", height: "60" %>
                <% end %>
                qr-branch
              </div>
              <br>
              <div class="text-center  m-auto">
                <h1 class="<%= Company.find_by(token: @token_company).name=='Bixi'  ? 'text-white' : '' %>  text-center mt-0 fw-bold">
                  <%= Company.find_by(token: @token_company).name.upcase %>
                </h1>
              </div>
              <br/>

              <br/>
              <%= render 'qr_branches/form_one_person', company: @company, person: @person, token_company: @token_company, token_branch: @token_branch, first_person: @first_person %>
            </div>
        </div> 
      </div>
    </div>
  </div>
</div>
