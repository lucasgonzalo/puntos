# -------------------------------Esto es para el codigo QR de Registro de Cliente---------------------------------------
<%= turbo_stream.replace("show_person_qr", partial: 'qr_branches/result_person', locals: {person: @person, company: @company}) %>
<%= turbo_stream.replace("show_customer_qr", partial: 'qr_branches/customer', locals: {person: @person,customer: @customer, company: @company}) %>


# -------------------------------Esto es para el codigo QR de consulta de saldos---------------------------------------
<%= turbo_stream.replace("person_search_result", partial: 'qr_branches/person', locals: {person: @person}) %>
<%= turbo_stream.replace("customer_search_result", partial: 'qr_branches/customer_result', locals: {customer: @customer}) %>