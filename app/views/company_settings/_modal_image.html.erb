<div class="modal-content">
  <div class="modal-header modal-colored-header bg-primary">
    <h4 class="modal-title" id="secundary-header-modalLabel">Imagen de Comercio</h4>
    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-hidden="true"></button>
  </div>
  <%= form_with(url: upload_image_company_path) do |form| %>
    <div class="modal-body">
      <div class="mb-3">
        <%= form.label 'Seleccione Imagen' %>
        <%= form.file_field :image_company, multiple: false, class: "form-control input-lg" %>
      </div>
    </div>
    <div class="modal-footer">
      <button type="button" class="btn btn-danger" data-bs-dismiss="modal">Cancelar</button>
      <%= form.submit "Confirmar", class: "btn btn-success " %>    
    </div>
  <% end %>
</div><!-- /.modal-content -->


