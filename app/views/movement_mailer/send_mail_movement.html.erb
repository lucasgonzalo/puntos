<div class="account-pages pt-2 pt-sm-5 pb-4 pb-sm-7">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-xxl-6 col-lg-12">
        <!--div class="card col-xs-4 col-sm-4 col-md-4 col-lg-4 col-xl-4" style="max-width:600px; border: 1px solid #0000cd !important; position: relative; background-color: transparent;"-->
        <div class="card col-xs-4 col-sm-4 col-md-4 col-lg-4 col-xl-4" style="width: 800px; high:200px; border: 1px solid #0000cd !important; background-color: <%= @branch.email_background_color%>;">
          <% if attachments['logo.png'].present? %>
            <div class="text-center">
              <%= image_tag attachments['logo.png'].url, alt: 'Imagen Superior logo', style: 'width: 100%; height: auto;' %>
            </div>
          <% end %>

          <% text_color = @branch.email_text_color ? @branch.email_text_color : 'black'%> 

          <div class="card-title">
            <div class="text-center  m-auto" style="font-size:1.5rem; margin-right: 1em; text-align: center; color: <%= text_color%>;">
              <h2 class=" text-center mt-0 fw-bold"><%= @company.name %></h2>
            </div>
          </div>
          <div class="card-body">
            <div class="text-center  m-auto" style="color: <%= text_color%>; font-size:1.5rem; margin-right: 1em; text-align: center;">
              <div class="row" style="font-family: arial; margin-right: 1em; color: <%= text_color%>;">
                Hola <b><%= @movement.customer.full_name %></b>!
              </div>
              <div class="row">
                <%= @msg.html_safe %>
              </div>
              <div class="row">
                <a href="<%= @url %>" style="display: inline-block; color: #fff; background-color: #17a2b8; padding: 5px 8px; text-decoration: none; border-radius: 5px; text-align: center;" target="_blank">IR A CTA. CTE.</a>
                <% if @branch.admits_product_exchange && @branch.get_related_catalog %>
                  <a href="<%= @catalog_url %>" style="display: inline-block; color: #fff; background-color: #17a2b8; padding: 5px 8px; text-decoration: none; border-radius: 5px; text-align: center;" target="_blank">VER CATALOGO</a>
                <% end %>
              </div>
              <br/>
              <div class="row" style="font-family: arial;color: <%= text_color%>;">
                Te esperamos<br>
                ¡Que tengas un hermoso día!
              </div>
              <br/>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

