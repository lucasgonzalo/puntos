<!-- lib/templates/erb/scaffold/_form.html.erb.tt -->

<%= form_with(model: @branch_setting) do |form| %>
  <%= render "shared/error_messages", resource: form.object %>
        
    <%= render 'inline_field', form: form, attribute: :day do %>
        <%= form.number_field :day, class: "form-control", placeholder:"Ingrese Día" %>
    <%end%>
  
    <%= render 'inline_field', form: form, attribute: :conversion do %>
        <%= form.text_field :conversion, class: "form-control", placeholder:"Ingrese Conversión" %>
    <%end%>

    <%= render 'inline_field', form: form, attribute: :discount do %>
        <%= form.text_field :discount, class: "form-control", placeholder:"Ingrese Descuento" %>
    <%end%>
  
  <div class="justify-between items-center">
    <%= form.button "Guardar", class: "btn btn-primary" %>
  </div>
<% end %>