<% title =  defined?(title) ? title : "" %>
<% type = defined?(type) ? type : "" %>

<%message = defined?(message) ? message : "Add parameters" %>

<% case type %>
  <% when "success" %>
    toastr.success('<%= message %>', '<%= title %>')
  <% when "info" %>
    toastr.info('<%= message %>', '<%= title %>')
  <% when "warning" %>
    toastr.warning('<%= message %>', '<%= title %>')
  <% when "error" %>
    toastr.error('<%= message %>', '<%= title %>')
  <% else %>
    toastr.info('<%= message %>', '<%= title %>')
<% end %>

toastr.options = {
  "closeButton": false,
  "debug": false,
  "newestOnTop": true,
  "progressBar": true,
  "positionClass": "toast-top-right",
  "preventDuplicates": false,
  "onclick": null,
  "showDuration": "300",
  "hideDuration": "800",
  "timeOut": "4000",
  "extendedTimeOut": "2000",
  "showEasing": "swing",
  "hideEasing": "linear",
  "showMethod": "fadeIn",
  "hideMethod": "fadeOut"
}