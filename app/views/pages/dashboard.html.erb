  <%= render partial: 'pages/dashboard_elements/customer_graphs' unless @current_branch %>
</div>

<%# Ejemplos de TurboFrame y Turbo Streams %>
<% if false %>
  <div class="my-2 p-1" style="border: 1px solid red;">
    <h2>Turbo stream example</h2>
    <p>Requires an extra file like: method_name.turbo_stream.rb (more flexible as it handles appends,etc.) </p>
    <%= form_with url: update_stream_content_path, data: { turbo_stream: true } do %>
      <%= submit_tag "Update Content", data: { disable_with: "Updating..." } %>
    <% end %>
    <div>Content to update with turbo_stream:</div>

    
    <div id="stream_content"><!--this id will be looked for update -->
      <%=  @new_text || "some random text to be updated" %>
    </div>
  </div>

  <div class="my-2 p1" style="border: 1px solid blue;">
    <h2>Turbo frame example</h2>
    <p>Requires an extra file like:  method_name.html.erb (ideal for on demand render like read heavy element) </p>
    <%= link_to "Update Content",
              update_frame_content_path,
              data: { turbo_frame: "frame_content", disable_with: "updating.." },
              class: "button" %>  <!-- Style as button via CSS -->

    <div>Content to update with turbo_frame:</div>
    <turbo-frame id="frame_content">
      <%= @content || "some random text to be updated" %>
    </turbo-frame>
  </div>
<% end %>
