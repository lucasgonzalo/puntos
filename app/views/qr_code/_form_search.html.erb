<%= form_with(url: search_person_customer_customers_path, class: "", method: :post, data_turbo: true) do |form| %>
<%#CustomersController#search_person_customer as TURBO_STREAM%>
  <label class="col-md-6 col-form-label mt-1" for="userName">
    <h6 class="">Nro. Documento</h6>
  </label>

  <% if !company.blank? %>
    <%= form.hidden_field :company_id, value: company.id %>
  <% end %>

  <%= form.hidden_field :document_type, value: "DNI" %>

  <div class="col-md-9">
    <%= form.text_field :document_number, class: 'form-control', placeholder: 'Ingrese Nro. de Documento' %>
  </div>

  <div class="col-md-9 mt-2">
    <%= form.submit "Buscar",  id: 'search_people' , disable_with: 'Submiting...', class: 'btn btn-primary'%>
  </div>
<% end %>