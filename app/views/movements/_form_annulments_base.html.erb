<%= form_with(model: movement, data:{
    turbo: true, 
    controller: 'companySetting', 
    companySetting_current_conversion_value: @conversion, 
    companySetting_current_discount_value: @discount,
    companySetting_current_type_value: type
  }) do |form| %>

  <%= render "shared/error_messages", resource: form.object %>
  <%= form.hidden_field :movement_type, value: type %>
  <%= form.hidden_field :customer_id, value: customer.id %>
  

  <div class="row justify-content-md-center">
    <div class="col-xl-8 col-lg-6">
      <div class="card tilebox-one card border-primary border">
        <div class="card-body">
          <h3 class="text-uppercase mt-0 text-center"><%= Movement.movement_types[type]%></h3>
          <%= form.hidden_field :movement_id, value: movement.id %>

          <table class="table table-nowrap table-centered mb-0">
            <tbody>
              
              <% if @current_branch %>
                <%= form.hidden_field :branch_id, value: @current_branch.id %>
                <tr>
                  <td><p class="m-0 d-inline-block align-middle">
                    <a href="apps-ecommerce-products-details.html" class="text-body fw-semibold">Sucursal</a><br>
                  </p></td>
                  <td class="text-end">
                    <%= form.text_field :branch_id, class: 'form-control', value: @current_branch.name, disabled: true%>
                  </td>
                </tr>
              <% else %>
                <div class="form-floating mb-4 col-md-12">
                    <%= form.collection_select :branch_id, Branch.all, :id, :name, {prompt: "Seleccione una Sucursal"}, {class: "form-select", required: true} %>
                    <%= form.label :branch_id, for: "floatingInput" %>
                </div>
              <% end %>

              <!------------- Aqui tenemos el IMPORTE que se ingresa ------------------->
              <%if type==:sale || type==:sale_annulment%>
                <%= render partial: 'movements/import_to_send', locals:{
                  movement: movement, 
                  form: form, 
                  type: type, 
                  value_type: "import"
                }%>
              <%else%>
                <%= form.hidden_field :amount, data:{ companySetting_target: "field" }%>
              <%end%>

              <!------------- Aqui tenemos los PUNTOS --------------------->
              <%= render partial: 'movements/conversion_discount_to_send', locals:{
                movement: movement, 
                form: form, 
                type: type, 
                value_type: "points"
              }%>


              <!-- Aqui tenemos los IMPORTE DESCONTADO -->
              <%if type==:sale || type==:sale_annulment%> 
                <%= render partial: 'movements/conversion_discount_to_send', locals:{movement: movement, form: form, type: type, value_type: "import_discount"}%>
              <%else%>
                <%= form.hidden_field :amount_discounted, data:{companySetting_target: "importDiscounted"} %>
              <%end%>


              <!---------------- Aqui tenemos el IMPORTE CON DESCUENTO ---------------------->
              <%if type==:sale || type==:sale_annulment%>
                <%= render partial: 'movements/import_to_send', locals:{ 
                  movement: movement, 
                  form: form, 
                  type: type, 
                  value_type: "import_with_discount"
                }%>
              <%else%>
                <%= form.hidden_field :amount_with_discount, data:{ companySetting_target: "amountWithDiscount" } %>
              <%end%>
              <!------------------------------------------------------------------------------------------------------------------------------>
            </tbody>
          </table>
          <br/>
          <div class="justify-between items-center">
            <%= form.button "Aceptar", class: "btn btn-primary" %>
          </div>
            
        </div> <!-- end card-body-->
      </div>
    </div> <!-- end col -->
  </div>

<% end %>
