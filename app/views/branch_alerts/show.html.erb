<!-- lib/templates/erb/scaffold/show.html.erb.tt -->

<% set_page_title("Alert") %>

<div class="row">
  <div class="col-12">
    <div class="card">
      <div class="card-body">
        <div class="m-2 col-12">
          <div class="container mx-auto my-2 px-4">
            <div class="box p-1">
              <div class="h4 m-2 text-lg font-semibold">Comercio:</div>
              <span class="leading-normal"><%= @alert.branch.company.name %></span>
            </div>
            <div class="box p-1">
              <div class="h4 m-2 text-lg font-semibold">Categoría:</div>
              <span class="leading-normal"><%= BranchAlert.categories[@alert.category] %></span>
            </div>
            <div class="box p-1">
              <div class="h4 m-2 text-lg font-semibold">Estado:</div>
              <span class="leading-normal"><%= BranchAlert.statuses[@alert.status ] %></span>
            </div>
            <div class="box p-1">
              <div class="h4 m-2 text-lg font-semibold">Contenido:</div>
              <span class="leading-normal"><%= @alert.content.to_s %></span>
            </div>
            <div class="box p-1">
              <div class="h4 m-2 text-lg font-semibold">Link:</div>
              <span class="leading-normal">
                <a href=<%= "http://#{request.host}:#{request.port}#{@alert.link}"%>> 
                  <%= "http://#{request.host}:#{request.port}#{@alert.link}" %>
                </a>
              </span>
            </div>
            
            <div class="mt-4justify-between items-center">
              <%#= button_to "Eliminar alert", @alert, method: :delete, class: 'btn btn-danger' if can? :destroy, @alert %>
            </div>
          </div>

          <div class="d-flex bd-highlight mb-3">
            <div class="p-2 bd-highlight">
              <%= link_to branch_alerts_path, class: "btn btn-secondary" do %>
                <i class="mdi mdi-arrow-left me-1"></i>
                Volver
              <% end %>
            </div>

            <div class="ms-auto p-2 bd-highlight">
              <% if can? :destroy, @alert %>
                <%#= render 'shared/destroy', element: @alert %>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>