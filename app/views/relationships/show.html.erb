<!-- lib/templates/erb/scaffold/show.html.erb.tt -->

<% set_page_title("Relationship") %>

<div class="row">
  <div class="col-12">
    <div class="card">
      <div class="card-body">
        <div class="m-2 col-12">
          <div class="container mx-auto my-2 px-4">

            <div class="box p-1">
              <div class="h4 m-2 text-lg font-semibold">Nombre:</div>
              <span class="leading-normal"><%= @relationship.name %></span>
            </div>
                  
          </div>

          <div class="d-flex bd-highlight mb-3">
            <div class="p-2 bd-highlight">
              <%= link_to 'Volver', relationships_path, class: "btn btn-secondary" %>
            </div>

            <div class="ms-auto p-2 bd-highlight">
              <% if can? :destroy, @relationship %>
                <%= render 'shared/destroy', element: @relationship %>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>