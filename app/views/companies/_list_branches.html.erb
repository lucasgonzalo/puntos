<table id="datatable-buttons" class="table table-striped dt-responsive nowrap ">
  <thead>
    <tr>
      <th class="p-3 uppercase text-left text-xs text-gray-700">Sucursal</th>
      <th class="p-3 uppercase text-left text-xs text-gray-700">Dirección</th>
      <th class="p-3 uppercase text-left text-xs text-gray-700">Ciudad</th>
      <th class="p-3 uppercase text-left text-xs text-gray-700"></th>
      <th class="p-3 uppercase text-left text-xs text-gray-700">Acciones</th>
    </tr>
  </thead>

  <tbody>
    <% @branches.each do |branch| %>
      <tr class="group border-t border-gray-400 hover:bg-gray-100">
        <td class="p-3"><%= branch.name %></td>
        <td class="p-3"><%= branch.address %></td>
        <td class="p-3"><%= branch.city.full_name %></td>
        <td class="p-3"><%= get_badges_branch(branch) %></td>
        <td>
          <%= link_to 'Ver', branch, class: "btn btn-outline-danger my-1" if can? :show, branch %>
          <%= link_to 'Empleados', show_branch_users_path(branch_id: branch.id), class: "btn btn-outline-danger my-1" if can? :show, branch %>
          <%= link_to 'Editar', edit_branch_path(branch.id), class: "btn btn-outline-danger" if can? :update, branch %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>