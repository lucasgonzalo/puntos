<table id="datatable-buttons" class="table table-striped dt-responsive nowrap ">
  <thead>
    <tr>
      <th class="p-3 uppercase text-left text-xs text-gray-700">Nombre</th>
      <th class="p-3 uppercase text-left text-xs text-gray-700">Documento</th>
      <th class="p-3 uppercase text-left text-xs text-gray-700">Puntos</th>
      <th class="p-3 uppercase text-left text-xs text-gray-700"></th>
      <th class="p-3 uppercase text-left text-xs text-gray-700">Acciones</th>
    </tr>
  </thead>

  <tbody>
    <% @customers.each do |customer| %>
      <tr class="group border-t border-gray-400 hover:bg-gray-100">
        <td class="p-3"><%= customer.full_name %></td>
        <td class="p-3"><%= customer.person.full_document %></td>
        <td class="p-3"><%#= customer.points_balance_amount(@company) %></td>
        <td class="p-3"><%= get_badges_customer(customer) %></td>
        <td>
          <%= link_to 'Ver', customer, class: "btn btn-outline-danger my-1" if can? :show, customer %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>