<!-- lib/templates/erb/scaffold/edit.html.erb.tt -->

<% set_page_title("Nuevo Cliente") %>

<div class="row">
  <div class="col-12 card">
    <div class="card-body">
      <div class="m-2 col-12">
        <div class="container mx-auto my-8 px-4">
          <div class="max-w-xl mx-auto">
            <%= render 'customer_wizard', customer: @customer %>
          </div>
        </div>

        <%= link_to 'Cancelar', customers_path, class: "btn btn-secondary m-4" %>
      </div>
    </div>
  </div>
</div>